# Production Environment Variables for Render
PORT=3000
NODE_ENV=production

# Database Configuration (will be set by Render service connections)
MONGO_URI=mongodb://admin:${MONGO_ROOT_PASSWORD}@mongodb:27017/trackly?authSource=admin

# JWT Configuration (will be generated by Render)
JWT_SECRET=${JWT_SECRET}
JWT_EXPIRE=7d

# Frontend URL (will be set by Render)
CLIENT_URL=https://trackly-frontend.onrender.com

# Service Configuration
MONGO_HOST=mongodb
MONGO_PORT=27017
